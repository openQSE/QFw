#!/usr/bin/env python3

import copy
import yaml, sys, getopt, os, stat
from datetime import datetime


CONTAINER_PROFILE_DEFAULTS = {
	'base-dir': '/workspace/qfw-container-base',
	'python-venv-activate': '/workspace/qfw-container-base/venv/bin/activate',
	'libfabric-install': '/opt/qfw/libfabric',
	'mpi-install': '/opt/qfw/openmpi',
	'dev-install': '/workspace/qfw-container-base/rocm',
}


def resolve_install_profile(cy):
	profile = cy.get('install-profile', '').strip().lower()
	if not profile:
		return cy
	if profile != 'container':
		raise ValueError(f"Unsupported install-profile '{profile}'")

	resolved = copy.deepcopy(cy)
	for key, value in CONTAINER_PROFILE_DEFAULTS.items():
		if not resolved.get(key):
			resolved[key] = value

	if resolved.get('qfw-module-path') or resolved.get('qfw-module-load'):
		raise ValueError("install-profile=container cannot be combined with module-based configuration")

	return resolved

def qfw_configure(cy):
	cy = resolve_install_profile(cy)
	base_dir = cy.get('base-dir', None)
	module_path = cy.get('qfw-module-path', None)
	module_file = cy.get('qfw-module-load', None)
	unloads = cy.get('module-unload', None)
	extra_mod_loads = cy.get('extra-module-load', None)
	python_activate = cy.get('python-venv-activate', None)
	req_install = cy.get('install-py-requirements', False)
	req_build = cy.get('build-dependencies', False)
	dep_build_version = cy.get('qfw-dep-build-version', None)

	if not base_dir or not python_activate:
		raise ValueError("Configuration file needs to specify: "
						 "base-dir and python-venv-activate entries")

	if req_build and not dep_build_version:
		dep_build_version = datetime.now().strftime("%Y%m%d-%H%M%S")
	if not req_build and not dep_build_version:
		raise ValueError("Configuration file needs to specify qfw-dep-build-version "
						 "when build-dependencies is false")

	qfw_setup_dir = os.path.join(base_dir, 'QFw', 'setup')
	qfw_env = os.path.join(base_dir, 'QFw', 'environment')

	os.makedirs(qfw_setup_dir, exist_ok=True)

	qfw_activate = os.path.join(qfw_setup_dir, 'qfw_activate')
	qfw_build_deps = os.path.join(qfw_setup_dir, 'qfw_build_deps.sh')

	with open(qfw_activate, 'w') as f:
		f.write('#!/usr/bin/env bash\n')
		f.write('# QFW activate (must be sourced)\n\n')

		f.write('if [[ -n "${_QFW_ACTIVE:-}" ]]; then\n')
		f.write('    echo "QFW environment already active"\n')
		f.write('    return 0\n')
		f.write('fi\n\n')

		f.write('export _QFW_OLD_PWD="$PWD"\n')
		f.write('export _QFW_ACTIVE=1\n')
		f.write('export _QFW_OLD_CMAKE_PREFIX_PATH="$CMAKE_PREFIX_PATH"\n')
		f.write('export _QFW_OLD_PE_PRODUCT_LIST="$PE_PRODUCT_LIST"\n')
		f.write('export _QFW_OLD_PKG_CONFIG_PATH="$PKG_CONFIG_PATH"\n')
		f.write('export _QFW_OLD_PE_PKGCONFIG_LIBS="$PE_PKGCONFIG_LIBS"\n')
		f.write('export _QFW_OLD_PATH="$PATH"\n')
		f.write('export _QFW_OLD_LD_LIBRARY_PATH="$LD_LIBRARY_PATH"\n')
		f.write('export _QFW_OLD_PYTHONPATH="$PYTHONPATH"\n')
		f.write(f'export _QFW_OLD_BLASLIB=$BLASLIB\n')
		f.write(f'export _QFW_OLD_BLAS_LIB_DIR=$BLAS_LIB_DIR\n')
		f.write(f'export _QFW_OLD_ACLOCAL_PATH=$ACLOCAL_PATH\n')

		f.write(f'export QFW_MASTER_SETUP_BASE_DIR="{base_dir}"\n')
		if dep_build_version:
			f.write(f'export QFW_DEP_BUILD_VERSION="{dep_build_version}"\n')
		f.write('if [[ -z "${QFW_DEP_BUILD_VERSION:-}" ]]; then\n')
		f.write('    echo "ERROR: QFW_DEP_BUILD_VERSION is not set. Re-run qfw_install with build-dependencies enabled or set qfw-dep-build-version in the config." >&2\n')
		f.write('    unset _QFW_ACTIVE\n')
		f.write('    return 1\n')
		f.write('fi\n\n')

		if module_path:
			f.write('export _QFW_USED_MODULES=1\n')
			if extra_mod_loads:
				f.write(f'module load {extra_mod_loads}\n')
			f.write(f'module use {module_path}\n')
			f.write(f'module load {module_file}\n')
			if unloads:
				f.write(f'module unload {unloads}\n')
			f.write(f'ml\n')
			f.write(f'export BLAS_LIB_DIR=$(pkg-config --variable=libdir openblas)\n')
		else:
			libfab_env = os.path.join(qfw_env, 'qfw_libfabric_env.sh')
			mpi_env = os.path.join(qfw_env, 'qfw_mpi_env.sh')
			qfw_vars = os.path.join(qfw_env, 'qfw_set_envvars.sh')
			dev_vars = os.path.join(qfw_env, 'qfw_dev_env.sh')

			libfab = cy.get('libfabric-install', None)
			mpi = cy.get('mpi-install', None)
			if not mpi:
				raise ValueError("MPI install path need to be specified")
			dev = cy.get('dev-install', None)
			# TODO: how do you handle other devices more generically? cuda?
			if not dev:
				raise ValueError("Need to install Device Library")

			openblas_root = cy.get('openblas-root', None)
			cmake_root = cy.get('cmake-root', None)
			gcc_root = cy.get('gcc-root', None)

			f.write(f'export QFW_MASTER_SETUP_MPI_INSTALL="{mpi}"\n')
			f.write(f'export QFW_MASTER_SETUP_DEV_INSTALL="{dev}"\n')
			if libfab:
				f.write(f'export QFW_MASTER_SETUP_LIBFABRIC_INSTALL="{libfab}"\n')
				f.write(f'source {libfab_env}\n')
			f.write(f'source {dev_vars}\n')
			f.write(f'source {mpi_env}\n')
			f.write(f'source {qfw_vars}\n')

			if openblas_root:
				f.write(f'export BLASLIB=OPENBLAS\n')
				f.write(f'export PATH="{openblas_root}/bin:$PATH"\n')
				f.write(f'export LD_LIBRARY_PATH="{openblas_root}/lib:$LD_LIBRARY_PATH"\n')
				f.write(f'export BLAS_LIB_DIR={openblas_root}/lib\n')
				f.write(f'export PKG_CONFIG_PATH="{openblas_root}/lib/pkgconfig:$PKG_CONFIG_PATH"\n')
				f.write(f'export CMAKE_PREFIX_PATH="{openblas_root}:$CMAKE_PREFIX_PATH"\n\n')

			if cmake_root:
				f.write(f'export PATH="{cmake_root}/bin:$PATH"\n')
				f.write(f'export ACLOCAL_PATH="{cmake_root}/share/aclocal:$ACLOCAL_PATH"\n')
				f.write(f'export CMAKE_PREFIX_PATH="{cmake_root}:$CMAKE_PREFIX_PATH"\n\n')

			if gcc_root:
				f.write(f'export PATH="{gcc_root}/bin:$PATH"\n')
				f.write(f'export GCC_PATH={gcc_root}\n')
				f.write(f'export GCC_PREFIX={gcc_root}\n')

		f.write(f'export QFW_VENV_PATH={os.path.dirname(os.path.dirname(python_activate))}\n')
		f.write(f'source {python_activate}\n\n')
		f.write(f'export PYTHON_PATH=$(which python3)\n')
		f.write('cd "$_QFW_OLD_PWD"\n\n')

		f.write('qfw_deactivate() {\n')
		f.write('    if [[ -z "${_QFW_ACTIVE:-}" ]]; then\n')
		f.write('        return 0\n')
		f.write('    fi\n\n')

		if module_path:
			f.write(f'    module unload {module_file}\n')
			f.write(f'    module unuse {module_path}\n')

		f.write('    if declare -f deactivate >/dev/null 2>&1; then\n')
		f.write('        deactivate\n')
		f.write('    fi\n\n')

		f.write('    export CMAKE_PREFIX_PATH=$_QFW_OLD_CMAKE_PREFIX_PATH\n')
		f.write('    export PE_PRODUCT_LIST=$_QFW_OLD_PE_PRODUCT_LIST\n')
		f.write('    export PKG_CONFIG_PATH=$_QFW_OLD_PKG_CONFIG_PATH\n')
		f.write('    export PE_PKGCONFIG_LIBS=$_QFW_OLD_PE_PKGCONFIG_LIBS\n')
		f.write('    export PATH="$_QFW_OLD_PATH"\n')
		f.write('    export LD_LIBRARY_PATH="$_QFW_OLD_LD_LIBRARY_PATH"\n')
		f.write('    export PYTHONPATH="$_QFW_OLD_PYTHONPATH"\n\n')
		f.write('    export BLASLIB=$_QFW_OLD_BLASLIB\n')
		f.write('    export BLAS_LIB_DIR=$_QFW_OLD_BLAS_LIB_DIR\n')
		f.write('    export ACLOCAL_PATH=$_QFW_OLD_ACLOCAL_PATH\n')

		f.write('    unset GCC_PATH\n')
		f.write('    unset GCC_PREFIX\n')
		f.write('    unset _QFW_ACTIVE\n')
		f.write('    unset _QFW_USED_MODULES\n')
		f.write('    unset _QFW_OLD_PATH\n')
		f.write('    unset _QFW_OLD_LD_LIBRARY_PATH\n')
		f.write('    unset _QFW_OLD_PYTHONPATH\n')
		f.write('    unset _QFW_OLD_PWD\n')
		f.write('    unset QFW_MASTER_SETUP_BASE_DIR\n')
		f.write('    unset QFW_DEP_BUILD_VERSION\n')
		f.write('    unset QFW_MASTER_SETUP_MPI_INSTALL\n')
		f.write('    unset QFW_MASTER_SETUP_LIBFABRIC_INSTALL\n\n')
		f.write('    unset QFW_VENV_PATH\n')
		f.write('    unset PYTHON_PATH\n\n')

		f.write('    unset -f qfw_deactivate\n')
		f.write('}\n')

	os.chmod(qfw_activate, os.stat(qfw_activate).st_mode | stat.S_IXUSR)

	with open(qfw_build_deps, 'w') as f:
		f.write('#!/usr/bin/env bash\n')
		f.write('set -e\n\n')
		f.write(f'source {qfw_activate}\n\n')
		f.write('cleanup() {\n')
		f.write('    if declare -f qfw_deactivate >/dev/null 2>&1; then\n')
		f.write('        qfw_deactivate\n')
		f.write('    fi\n')
		f.write('}\n')
		f.write('trap cleanup EXIT\n\n')

		if req_install:
			f.write(f'cd {base_dir}/QFw/backends\n')
			f.write('pip3 install -e .\n')
			f.write(f'cd {base_dir}/QFw/DEFw\n')
			f.write('python -m pip install -r requirements.txt\n')
			f.write(f'cd {base_dir}/QFw/setup\n')
			f.write('python -m pip install -r requirements.txt\n\n')

		if req_build:
			f.write('if [[ -z "${QFW_DEP_BUILD_VERSION:-}" ]]; then\n')
			f.write(f'    export QFW_DEP_BUILD_VERSION="{dep_build_version}"\n')
			f.write('fi\n')
			f.write(f'{os.path.join(base_dir, "QFw", "patches", "tnqvm", "build.sh")}\n')
			f.write(f'{os.path.join(base_dir, "QFw", "patches", "nwqsim", "build.sh")}\n')
			f.write(f'{os.path.join(base_dir, "QFw", "DEFw", "build.sh")}\n\n')

		if not req_install and not req_build:
			f.write('echo "No dependency installation or build steps were requested."\n')

		f.write(f'cd {base_dir}/QFw\n')

	os.chmod(qfw_build_deps, os.stat(qfw_build_deps).st_mode | stat.S_IXUSR)

def print_help():
	print("Usage:")
	print("   ./qfw_install -c <config.yaml>")
	print("")
	print("This generates:")
	print("   <base-dir>/QFw/setup/qfw_activate")
	print("   <base-dir>/QFw/setup/qfw_build_deps.sh")
	print("")
	print("Run qfw_build_deps.sh separately to install Python requirements")
	print("and build optional dependencies.")

def main(argv):
	try:
		options, args = getopt.getopt(argv, "c:h",
				["config=", "help"])
	except Exception as e:
		print(f"Bad command line arguments {argv}")
		raise(e)

	config = None
	for name, value in options:
		if name in ['-c', '--config']:
			config = value
		elif name in ['-h', '--help']:
			print_help()
			exit(1)
		else:
			print(f"Unrecognized parameter: {name}")
			print_help()
			exit(1)

	if not config:
		print_help()
		exit(1)

	with open(config, 'r') as f:
		cy = yaml.load(f, Loader=yaml.FullLoader)
		qfw_configure(cy)

if __name__ == '__main__':
	argv = sys.argv[1:]
	main(argv)
