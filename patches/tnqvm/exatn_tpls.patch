                               EXA_TALSH_ONLY=YES
                               EXATN_SERVICE=YES
                               EXA_OS=LINUX
-                              GPU_CUDA=NOCUDA
+                              GPU_CUDA=${GPU_CUDA}
                               MPILIB=NONE
                               BLASLIB=${BLAS_LIB}
                               PATH_BLAS_${BLAS_LIB}=${BLAS_PATH}
@@ -392,7 +403,7 @@ else()
                               EXA_TALSH_ONLY=YES #reset to "NO" for full ExaTENSOR
                               EXATN_SERVICE=YES
                               EXA_OS=LINUX
-                              GPU_CUDA=NOCUDA
